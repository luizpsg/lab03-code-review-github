# Token de acesso pessoal do GitHub (com escopo public_repo).
# Gere em: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_seu_token_aqui

# Numero maximo de PRs coletados por repositorio (mais recentes primeiro).
# Default sugerido pelo enunciado: 200.
PR_LIMIT_PER_REPO=200

# Numero alvo de repositorios mais populares a coletar.
TOP_REPOS=200

# Numero minimo de PRs (MERGED + CLOSED) para o repositorio ser mantido.
MIN_PRS_PER_REPO=100
